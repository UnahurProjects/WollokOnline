# ─────────────────────────────────────────────────────────────
# Wollok Exam Online — variables de entorno (ejemplo)
# Copiar a .env.local y completar. NO commitear .env.local.
#
# GitHub es la ÚNICA fuente de verdad del examen (no hay base de datos).
# El browser NUNCA recibe tokens de GitHub: todo el I/O pasa por Route Handlers.
# ─────────────────────────────────────────────────────────────

# Auth.js (NextAuth) — login GitHub solo para identidad
AUTH_URL=http://localhost:3000
AUTH_SECRET=                      # generar: openssl rand -base64 32
AUTH_GITHUB_ID=                   # OAuth App client id
AUTH_GITHUB_SECRET=               # OAuth App client secret

# Docentes (override opcional de lib/config/teachers.ts). Lista separada por comas.
TEACHERS=

# Código para la exportación de emergencia (descarga .zip del alumno).
# Lo conocen solo los docentes. Si está vacío, la exportación (online) queda deshabilitada.
# Validación ONLINE: contra EXPORT_CODE en el server (la clave nunca llega al cliente).
EXPORT_CODE=

# Validación OFFLINE (sin internet): hash SHA-256 del MISMO código, embebido en el cliente.
# Generar:  node -e "console.log(require('crypto').createHash('sha256').update('TU_CODIGO').digest('hex'))"
# (o:  printf '%s' 'TU_CODIGO' | sha256sum). Dejar vacío para no permitir export offline.
NEXT_PUBLIC_EXPORT_CODE_HASH=

# Integración GitHub: mock | app
GITHUB_INTEGRATION_MODE=mock

# Organización destino (donde se crean los repos por alumno)
GITHUB_DEFAULT_ORG=ExamUnahurP

# GitHub App (requerido solo cuando GITHUB_INTEGRATION_MODE=app)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# Clave privada: O BIEN el contenido del .pem en GITHUB_APP_PRIVATE_KEY
# (una línea con \n escapados), O BIEN la ruta a un archivo .pem:
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=.secrets/github-app.pem
